{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-stripe" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" class="btn btn-default"><i class="fa fa-reply"></i> {{ button_cancel }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible">
      <i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&#215;</button>
    </div>
    {% endif %}

    <!-- Webhook URL -->
    <div class="alert alert-info">
      <i class="fa fa-info-circle"></i>
      <strong>Stripe Webhook URL:</strong>
      <code>{{ webhook_url }}</code><br>
      <small>Add this URL in Stripe Dashboard → Developers → Webhooks. Required events: <strong>payment_intent.succeeded</strong>, <strong>payment_intent.payment_failed</strong></small>
    </div>

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" id="form-stripe" class="form-horizontal">

          <!-- Publishable Key -->
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_publishable_key }} <span class="text-danger">*</span></label>
            <div class="col-sm-6">
              <input type="text" name="payment_stripe_publishable_key"
                     value="{{ payment_stripe_publishable_key }}"
                     placeholder="pk_live_... or pk_test_..."
                     class="form-control" autocomplete="off" />
              <span class="help-block">{{ help_publishable_key }}</span>
            </div>
          </div>

          <!-- Secret Key -->
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_secret_key }} <span class="text-danger">*</span></label>
            <div class="col-sm-6">
              <input type="password" name="payment_stripe_secret_key"
                     value="{{ payment_stripe_secret_key }}"
                     placeholder="sk_live_... or sk_test_..."
                     class="form-control" autocomplete="new-password" />
              <span class="help-block">{{ help_secret_key }}</span>
            </div>
          </div>

          <!-- Webhook Secret -->
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_webhook_secret }}</label>
            <div class="col-sm-6">
              <input type="password" name="payment_stripe_webhook_secret"
                     value="{{ payment_stripe_webhook_secret }}"
                     placeholder="whsec_..."
                     class="form-control" autocomplete="new-password" />
              <span class="help-block">{{ help_webhook_secret }}</span>
            </div>
          </div>

          <!-- Order Status -->
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_order_status }}</label>
            <div class="col-sm-4">
              <select name="payment_stripe_order_status_id" class="form-control">
                {% for order_status in order_statuses %}
                <option value="{{ order_status.order_status_id }}"
                  {% if order_status.order_status_id == payment_stripe_order_status_id %}selected{% endif %}>
                  {{ order_status.name }}
                </option>
                {% endfor %}
              </select>
            </div>
          </div>

          <!-- Stripe Link -->
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_link_status }}</label>
            <div class="col-sm-3">
              <select name="payment_stripe_link_status" class="form-control">
                <option value="1" {% if payment_stripe_link_status != '0' %}selected{% endif %}>{{ text_enabled }}</option>
                <option value="0" {% if payment_stripe_link_status == '0' %}selected{% endif %}>{{ text_disabled }}</option>
              </select>
              <span class="help-block">{{ help_link_status }}</span>
            </div>
          </div>

          <!-- Test Mode -->
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_test_mode }}</label>
            <div class="col-sm-3">
              <select name="payment_stripe_test_mode" class="form-control">
                <option value="1" {% if payment_stripe_test_mode == '1' %}selected{% endif %}>{{ text_yes }}</option>
                <option value="0" {% if payment_stripe_test_mode == '0' %}selected{% endif %}>{{ text_no }}</option>
              </select>
            </div>
          </div>

          <!-- Status -->
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_status }}</label>
            <div class="col-sm-3">
              <select name="payment_stripe_status" class="form-control">
                <option value="1" {% if payment_stripe_status == '1' %}selected{% endif %}>{{ text_enabled }}</option>
                <option value="0" {% if payment_stripe_status == '0' %}selected{% endif %}>{{ text_disabled }}</option>
              </select>
            </div>
          </div>

          <!-- Sort Order -->
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_sort_order }}</label>
            <div class="col-sm-2">
              <input type="text" name="payment_stripe_sort_order"
                     value="{{ payment_stripe_sort_order }}"
                     class="form-control" style="width:80px" />
            </div>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
